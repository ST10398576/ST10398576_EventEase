@model ST10398576_EventEase.Models.Venue
@{
    ViewData["Title"] = "Edit Venue";
}

<h2>Edit Venue</h2>

<form asp-action="Edit" asp-route-id="@Model.VenueId" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="VenueId" />

    <div>
        <label asp-for="VenueName"></label>
        <input asp-for="VenueName" />
        <span asp-validation-for="VenueName" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Location"></label>
        <input asp-for="Location" />
        <span asp-validation-for="Location" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Capacity"></label>
        <input asp-for="Capacity" type="number" />
        <span asp-validation-for="Capacity" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="ImageUrl">Image URL</label>
        <input asp-for="ImageUrl" />
        <span asp-validation-for="ImageUrl" class="text-danger"></span>
    </div>

    <div>
        <button type="submit">Save</button>
        <a asp-action="Index">Cancel</a>
    </div>
</form>