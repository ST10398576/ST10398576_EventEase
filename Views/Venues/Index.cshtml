@model IEnumerable<ST10398576_EventEase.Models.Venue>
@{
    ViewData["Title"] = "Venues";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Venues</h2>
        <a asp-action="Create" class="btn btn-success">+ Create New Venue</a>
    </div>

    <div class="row">
        @foreach (var venue in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <img src="@venue.ImageUrl" class="card-img-top" alt="@venue.VenueName" />
                    <div class="card-body">
                        <h5 class="card-title">@venue.VenueName</h5>
                        <p class="card-text">
                            <strong>Location:</strong> @venue.Location <br />
                            <strong>Capacity:</strong> @venue.Capacity
                        </p>
                        <div class="btn-group" role="group">
                            <a asp-action="Details" asp-route-id="@venue.VenueId" class="btn btn-primary btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@venue.VenueId" class="btn btn-warning btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@venue.VenueId" class="btn btn-danger btn-sm">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>