@model IEnumerable<ST10398576_EventEase.Models.Venue>
@{
    ViewData["Title"] = "Venues";
}

<h2>Venues</h2>
<p>
    <a asp-action="Create" class="btn btn-primary mb-3">Create New Venue</a>
</p>

<div class="table-responsive">
    <table class="table table-striped table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Location</th>
                <th>Capacity</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var venue in Model)
            {
                <tr>
                    <td style="width:140px;">
                        @if (!string.IsNullOrEmpty(venue.ImageUrl))
                        {
                            <img src="@venue.ImageUrl" alt="@venue.VenueName" class="img-thumbnail" style="max-width:120px; max-height:80px;" />
                        }
                        else
                        {
                            <span class="text-muted">No image</span>
                        }
                    </td>
                    <td>@venue.VenueName</td>
                    <td>@venue.Location</td>
                    <td>@venue.Capacity</td>
                    <td class="text-center">
                        <div class="btn-group" role="group" aria-label="Actions">
                            <a asp-action="Details" asp-route-id="@venue.VenueId" class="btn btn-sm btn-outline-primary">Details</a>
                            <a asp-action="Edit" asp-route-id="@venue.VenueId" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@venue.VenueId" class="btn btn-sm btn-outline-danger">Delete</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>