@model ST10398576_EventEase.Models.Venue
@{
    ViewData["Title"] = "Venue Details";
}

<h2>@Model.VenueName</h2>

<div>
    <p><strong>Location:</strong> @Model.Location</p>
    <p><strong>Capacity:</strong> @Model.Capacity</p>
    <p><strong>Image URL:</strong> @Model.ImageUrl</p>
</div>

<p>
    <a asp-action="Edit" asp-route-id="@Model.VenueId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</p>