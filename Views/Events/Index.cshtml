@model IEnumerable<ST10398576_EventEase.Models.Event>
@{
    ViewData["Title"] = "Events";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Events</h2>
        <a asp-action="Create" class="btn btn-success">+ Create New Event</a>
    </div>

    <div class="row">
        @foreach (var ev in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">@ev.EventName</h5>
                        <p class="card-text">
                            <strong>Date:</strong> @ev.EventDate.ToString("dd MMM yyyy") <br />
                            <strong>Venue:</strong> @ev.Venue?.VenueName <br />
                            <strong>Description:</strong> @ev.Description
                        </p>
                        <div class="btn-group" role="group">
                            <a asp-action="Details" asp-route-id="@ev.EventId" class="btn btn-primary btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@ev.EventId" class="btn btn-warning btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@ev.EventId" class="btn btn-danger btn-sm">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>