@model ST10398576_EventEase.Models.Event
@{
    ViewData["Title"] = "Event Details";
}

<div class="container mt-4">
    <h2 class="mb-4">Event Details</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title">@Model.EventName</h5>
            <p class="card-text">
                <strong>Date:</strong> @Model.EventDate.ToString("dd MMM yyyy") <br />
                <strong>Venue:</strong> @Model.Venue?.VenueName <br />
                <strong>Description:</strong> @Model.Description
            </p>
            <a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>