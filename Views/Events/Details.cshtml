@model ST10398576_EventEase.Models.Event
@{
    ViewData["Title"] = "Event Details";
}

<h2>@Model.EventName</h2>

<div>
    <p><strong>Date:</strong> @Model.EventDate.ToString("dd MMM yyyy")</p>
    <p><strong>Venue:</strong> @Model.Venue?.VenueName</p>
    <p><strong>Description:</strong> @Model.Description</p>

    <p>
        <a asp-action="Edit" asp-route-id="@Model.EventId">Edit</a> |
        <a asp-action="Index">Back to List</a>
    </p>
</div>