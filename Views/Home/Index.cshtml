@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="mb-4">Welcome to EventEase</h1>
    <p class="lead">Manage your venues, events, and bookings with ease.</p>

    <div class="row mt-5">
        <div class="col-md-4 mb-3">
            <div class="card border-primary h-100">
                <div class="card-body d-flex align-items-center justify-content-center">
                    <a asp-controller="Venues" asp-action="Index" class="btn btn-outline-primary btn-lg w-100">View Venues</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-success h-100">
                <div class="card-body d-flex align-items-center justify-content-center">
                    <a asp-controller="Events" asp-action="Index" class="btn btn-outline-success btn-lg w-100">View Events</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-warning h-100">
                <div class="card-body d-flex align-items-center justify-content-center">
                    <a asp-controller="Bookings" asp-action="Index" class="btn btn-outline-warning btn-lg w-100">View Bookings</a>
                </div>
            </div>
        </div>
    </div>
</div>