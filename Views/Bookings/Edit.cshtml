@model ST10398576_EventEase.Models.Booking
@{
    ViewData["Title"] = "Edit Booking";
    var events = ViewBag.Events as List<ST10398576_EventEase.Models.Event> ?? new List<ST10398576_EventEase.Models.Event>();
}

<h2>Edit Booking</h2>

<form asp-action="Edit" asp-route-id="@Model.BookingId" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="BookingId" />

    <div>
        <label asp-for="EventId">Event</label>
        <select asp-for="EventId" id="EventId" class="form-select">
            <option value="">-- Select event --</option>
            @foreach (var ev in events)
            {
                <option value="@ev.EventId"
                        data-venue-name="@ev.Venue?.VenueName"
                        data-event-date="@ev.EventDate.ToString("yyyy-MM-dd")"
                        selected="@(ev.EventId == Model.EventId ? "selected" : null)">
                    @ev.EventName
                </option>
            }
        </select>
        <span asp-validation-for="EventId" class="text-danger"></span>
    </div>

    <div class="mt-3">
        <label asp-for="BookingDate">Event Date</label>
        <input asp-for="BookingDate" id="EventDateDisplay" readonly class="form-control" />
        <span asp-validation-for="BookingDate" class="text-danger"></span>
    </div>

    <div class="mt-3">
        <label>Venue</label>
        <input id="VenueNameDisplay" readonly class="form-control" />
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </div>
</form>

@section Scripts {
    <script>
        (function () {
            var eventSelect = document.getElementById('EventId');
            var venueDisplay = document.getElementById('VenueNameDisplay');
            var dateDisplay = document.getElementById('EventDateDisplay');

            function updateDisplays() {
                var opt = eventSelect.options[eventSelect.selectedIndex];
                if (!opt || !opt.value) {
                    venueDisplay.value = '';
                    dateDisplay.value = '';
                    return;
                }
                venueDisplay.value = opt.getAttribute('data-venue-name') || '';
                dateDisplay.value = opt.getAttribute('data-event-date') || '';
            }

            eventSelect.addEventListener('change', updateDisplays);
            updateDisplays();
        })();
    </script>
}