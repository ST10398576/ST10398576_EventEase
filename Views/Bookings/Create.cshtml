@model ST10398576_EventEase.Models.Booking
@{
    ViewData["Title"] = "Create Booking";
}

<div class="container mt-4">
    <h2 class="mb-4">Create New Booking</h2>

    <form asp-action="Create" class="needs-validation" novalidate>
        <div class="mb-3">
            <label asp-for="BookingDate" class="form-label"></label>
            <input asp-for="BookingDate" type="date" class="form-control" />
            <span asp-validation-for="BookingDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EventId" class="form-label">Event</label>
            <select asp-for="EventId" asp-items="ViewBag.EventId" class="form-select"></select>
            <span asp-validation-for="EventId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="VenueId" class="form-label">Venue</label>
            <select asp-for="VenueId" asp-items="ViewBag.VenueId" class="form-select"></select>
            <span asp-validation-for="VenueId" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>