@model ST10398576_EventEase.Models.Booking
@{
    ViewData["Title"] = "Create Booking";
    var events = ViewBag.Events as List<ST10398576_EventEase.Models.Event> ?? new List<ST10398576_EventEase.Models.Event>();
}

<div class="container mt-4">
    <h2 class="mb-4">Create New Booking</h2>

    <form asp-action="Create" method="post" class="needs-validation" novalidate>
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="EventId" class="form-label">Event</label>
            <select asp-for="EventId" id="EventId" class="form-select">
                <option value="">-- Select event --</option>
                @foreach (var ev in events)
                {
                    <option value="@ev.EventId" data-venue-name="@ev.Venue?.VenueName" data-event-date="@ev.EventDate.ToString("yyyy-MM-dd")">@ev.EventName</option>
                }
            </select>
            <span asp-validation-for="EventId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Event Date</label>
            <input id="EventDateDisplay" class="form-control" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">Venue</label>
            <input id="VenueNameDisplay" class="form-control" readonly />
        </div>

        <button type="submit" class="btn btn-success">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>

@section Scripts {
    <script>
        (function () {
            var eventSelect = document.getElementById('EventId');
            var venueDisplay = document.getElementById('VenueNameDisplay');
            var dateDisplay = document.getElementById('EventDateDisplay');

            function updateDisplays() {
                var opt = eventSelect.options[eventSelect.selectedIndex];
                if (!opt || !opt.value) {
                    venueDisplay.value = '';
                    dateDisplay.value = '';
                    return;
                }
                var vName = opt.getAttribute('data-venue-name') || '';
                var eDate = opt.getAttribute('data-event-date') || '';
                venueDisplay.value = vName;
                dateDisplay.value = eDate;
            }

            eventSelect.addEventListener('change', updateDisplays);
            updateDisplays();
        })();
    </script>
}