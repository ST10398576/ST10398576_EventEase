@model IEnumerable<ST10398576_EventEase.Models.Booking>
@{
    ViewData["Title"] = "Bookings";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Bookings</h2>
        <a asp-action="Create" class="btn btn-success">+ Create New Booking</a>
    </div>

    <div class="row">
        @foreach (var booking in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">Booking #@booking.BookingId</h5>
                        <p class="card-text">
                            <strong>Date:</strong> @booking.BookingDate.ToString("dd MMM yyyy") <br />
                            <strong>Event:</strong> @booking.Event?.EventName <br />
                            <strong>Venue:</strong> @booking.Venue?.VenueName
                        </p>
                        <div class="btn-group" role="group">
                            <a asp-action="Details" asp-route-id="@booking.BookingId" class="btn btn-primary btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@booking.BookingId" class="btn btn-warning btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@booking.BookingId" class="btn btn-danger btn-sm">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>