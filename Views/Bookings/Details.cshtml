@model ST10398576_EventEase.Models.Booking
@{
    ViewData["Title"] = "Booking Details";
}

<div class="container mt-4">
    <h2 class="mb-4">Booking Details</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Booking #@Model.BookingId</h5>
            <p class="card-text">
                <strong>Date:</strong> @Model.BookingDate.ToString("dd MMM yyyy") <br />
                <strong>Event:</strong> @Model.Event?.EventName <br />
                <strong>Venue:</strong> @Model.Venue?.VenueName
            </p>
            <a asp-action="Edit" asp-route-id="@Model.BookingId" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>