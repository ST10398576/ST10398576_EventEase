@model ST10398576_EventEase.Models.Booking
@{
    ViewData["Title"] = "Delete Booking";
}

<h2>Delete Booking</h2>

<p>Are you sure?</p>

<div>
    <p><strong>Event:</strong> @Model.Event?.EventName</p>
    <p><strong>Date:</strong> @Model.BookingDate.ToString("dd MMM yyyy")</p>
</div>

<form asp-action="Delete" method="post" asp-route-id="@Model.BookingId">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="BookingId" />
    <button type="submit">Delete</button>
    <a asp-action="Index">Cancel</a>
</form>
